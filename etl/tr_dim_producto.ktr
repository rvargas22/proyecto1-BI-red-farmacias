  <step>
    <name>TI_Producto_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>red_farmacias</connection>
    <sql>SELECT
    pr.id_producto AS id_producto_origen,
    pr.codigo_producto,
    pr.nombre_producto,
    cp.nombre_categoria AS categoria_producto,
    lb.nombre_laboratorio,
    lb.pais_origen AS pais_origen_laboratorio,
    pr.tipo_producto,
    pr.presentacion,
    pr.unidad_medida,
    pr.precio_venta_referencia,
    pr.costo_referencia,
    pr.requiere_receta,
    pr.estado AS estado_producto
FROM oltp_farmacia.producto pr
JOIN oltp_farmacia.categoria_producto cp
    ON pr.id_categoria = cp.id_categoria
JOIN oltp_farmacia.laboratorio lb
    ON pr.id_laboratorio = lb.id_laboratorio;</sql>
    <limit>0</limit>
    <lookup/>
