  <step>
    <name>TI_Cliente_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>red_farmacias</connection>
    <sql>SELECT
    id_cliente AS id_cliente_origen,
    codigo_cliente,
    tipo_identificacion,
    numero_identificacion,
    TRIM(
        COALESCE(nombre, '') || ' ' ||
        COALESCE(apellido_1, '') || ' ' ||
        COALESCE(apellido_2, '')
    ) AS nombre_completo,
    sexo,
    fecha_nacimiento,
    EXTRACT(YEAR FROM AGE(CURRENT_DATE, fecha_nacimiento))::int AS edad,
    CASE
        WHEN EXTRACT(YEAR FROM AGE(CURRENT_DATE, fecha_nacimiento)) &lt; 18 THEN 'Menor de edad'
        WHEN EXTRACT(YEAR FROM AGE(CURRENT_DATE, fecha_nacimiento)) BETWEEN 18 AND 25 THEN '18 a 25'
        WHEN EXTRACT(YEAR FROM AGE(CURRENT_DATE, fecha_nacimiento)) BETWEEN 26 AND 35 THEN '26 a 35'
        WHEN EXTRACT(YEAR FROM AGE(CURRENT_DATE, fecha_nacimiento)) BETWEEN 36 AND 50 THEN '36 a 50'
        WHEN EXTRACT(YEAR FROM AGE(CURRENT_DATE, fecha_nacimiento)) BETWEEN 51 AND 65 THEN '51 a 65'
        ELSE 'Mayor de 65'
    END AS rango_etario,
    telefono,
    correo,
    fecha_registro,
    estado AS estado_cliente
FROM oltp_farmacia.cliente;</sql>
