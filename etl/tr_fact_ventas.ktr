  <step>
    <name>TI_Fact_Ventas_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>red_farmacias</connection>
    <sql>SELECT
    v.id_venta,
    DATE(v.fecha_venta) AS fecha_venta_dia,
    v.id_sucursal,
    dv.id_producto,
    v.id_cliente,
    v.numero_venta,
    v.metodo_pago,
    dv.cantidad AS cantidad_vendida,
    dv.precio_unitario_venta,
    dv.costo_unitario_venta,
    (dv.cantidad * dv.precio_unitario_venta) AS venta_bruta,
    COALESCE(dv.descuento_linea, 0) AS descuento,
    ROUND(((dv.cantidad * dv.precio_unitario_venta) - COALESCE(dv.descuento_linea, 0)) * 0.13, 2) AS impuesto,
    ROUND(((dv.cantidad * dv.precio_unitario_venta) - COALESCE(dv.descuento_linea, 0)) * 1.13, 2) AS venta_neta,
    (dv.cantidad * dv.costo_unitario_venta) AS costo_total,
    ROUND(
        (
            ((dv.cantidad * dv.precio_unitario_venta) - COALESCE(dv.descuento_linea, 0)) * 1.13
        ) - (dv.cantidad * dv.costo_unitario_venta),
        2
    ) AS margen_bruto,
    v.estado AS estado_venta
FROM oltp_farmacia.venta v
JOIN oltp_farmacia.detalle_venta dv
    ON v.id_venta = dv.id_venta;</sql>
