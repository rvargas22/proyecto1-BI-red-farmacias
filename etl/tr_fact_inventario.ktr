  <step>
    <name>TI_Fact_Inventario_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>red_farmacias</connection>
    <sql>SELECT
    DATE(mi.fecha_movimiento) AS fecha_movimiento_dia,
    mi.id_sucursal,
    mi.id_producto,
    i.stock_actual,
    i.stock_minimo,
    i.stock_maximo,
    mi.tipo_movimiento,
    mi.cantidad AS cantidad_movimiento,
    mi.costo_unitario,
    (i.stock_actual * mi.costo_unitario) AS costo_inventario,
    mi.referencia AS referencia_movimiento
FROM oltp_farmacia.movimiento_inventario mi
JOIN oltp_farmacia.inventario_sucursal i
    ON mi.id_sucursal = i.id_sucursal
   AND mi.id_producto = i.id_producto;</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
