  <step>
    <name>TI_Fechas_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>red_farmacias</connection>
    <sql>SELECT DISTINCT
    fecha_base AS fecha_completa,
    EXTRACT(DAY FROM fecha_base)::int AS dia,
    TRIM(TO_CHAR(fecha_base, 'TMDay')) AS nombre_dia,
    EXTRACT(WEEK FROM fecha_base)::int AS semana,
    EXTRACT(MONTH FROM fecha_base)::int AS mes,
    TRIM(TO_CHAR(fecha_base, 'TMMonth')) AS nombre_mes,
    EXTRACT(QUARTER FROM fecha_base)::int AS trimestre,
    EXTRACT(YEAR FROM fecha_base)::int AS anio,
    CASE
        WHEN EXTRACT(MONTH FROM fecha_base) &lt;= 6 THEN 1
        ELSE 2
    END AS semestre
FROM (
    SELECT DATE(fecha_venta) AS fecha_base
    FROM oltp_farmacia.venta

    UNION

    SELECT DATE(fecha_movimiento) AS fecha_base
    FROM oltp_farmacia.movimiento_inventario
) t
ORDER BY fecha_completa;</sql>
